# ===== MySQL 连接配置 =====
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=your_database
MYSQL_CHARSET=utf8mb4

# ===== 安全配置 =====
# true = 只允许 SELECT/SHOW/DESCRIBE/EXPLAIN
READ_ONLY=false
# true = 允许 CREATE/ALTER/DROP/TRUNCATE
ALLOW_DDL=false
# 单次查询最多返回行数
MAX_RESULT_ROWS=1000
# 查询超时（秒），对应 MySQL MAX_EXECUTION_TIME
QUERY_TIMEOUT=30

# ===== 连接池 =====
POOL_SIZE=5
POOL_MAX_OVERFLOW=5

# ===== 审计 & 导出 =====
# 是否启用审计日志（exports/audit.log）
AUDIT_LOG=true
# CSV/JSON 导出目录
EXPORT_DIR=./exports
# 查询历史保留条数（内存中）
QUERY_HISTORY_LIMIT=50

# ===== 传输模式 =====
# stdio / sse / streamable-http
MCP_TRANSPORT=stdio
# HTTP/SSE 监听地址（仅非 stdio 模式生效）
MCP_HOST=127.0.0.1
MCP_PORT=8000
